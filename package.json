{
  "name": "videoedit",
  "version": "1.0.0",
  "description": "Webapp for creating 2D vector videos with AI-powered script interpretation",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "build:all": "npm run build && npm run build:server",
    "build:server": "node build-server.js",
    "start": "node server.js",
    "install:all": "npm install && cd client && npm install",
    "docker:build": "docker build -t videoedit:latest .",
    "docker:run": "docker run -p 3000:3000 -p 5000:5000 videoedit:latest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "body-parser": "^1.20.2",
    "multer": "^1.4.5-lts.1",
    "ffmpeg-static": "^5.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "sharp": "^0.32.6",
    "uuid": "^9.0.1",
    "axios": "^1.6.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.1"
  }
}
